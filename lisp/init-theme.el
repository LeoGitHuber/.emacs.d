(defun my/ensure-modus-themes ()
  "Load the Modus theme support library from the built-in themes directory."
  (add-to-list 'load-path my/modus-themes-directory)
  (add-to-list 'custom-theme-load-path my/modus-themes-directory)
  (require 'modus-themes))

(defun my/disable-active-themes ()
  "Disable all currently active custom themes."
  (mapc #'disable-theme custom-enabled-themes))

(defun my/run-theme-dependent-refresh ()
  "Refresh theme-dependent UI components once after theme changes settle."
  (when (fboundp 'segment-line-refresh-faces)
    (segment-line-refresh-faces))
  (when (fboundp 'my/flymake-refresh-fancy-theme)
    (my/flymake-refresh-fancy-theme)))

(defun my/apply-gits-theme-faces ()
  "Apply the extra face overrides used by the emacs-solo GITS preset."
  (custom-theme-set-faces
   'user
   '(change-log-acknowledgment ((t (:foreground "#00e5ff"))))
   '(change-log-date ((t (:foreground "#00cc77"))))
   '(change-log-name ((t (:foreground "#ffaa00"))))
   '(diff-context ((t (:foreground "#1a3a50"))))
   '(diff-file-header ((t (:foreground "#ff4466"))))
   '(diff-header ((t (:foreground "#00e5ff"))))
   '(diff-hunk-header ((t (:foreground "#ffaa00"))))
   '(gnus-button ((t (:foreground "#00e5ff"))))
   '(gnus-group-mail-3 ((t (:foreground "#00e5ff"))))
   '(gnus-group-mail-3-empty ((t (:foreground "#00e5ff"))))
   '(gnus-header-content ((t (:foreground "#68b8cc"))))
   '(gnus-header-from ((t (:foreground "#cc55ff"))))
   '(gnus-header-name ((t (:foreground "#00cc77"))))
   '(gnus-header-subject ((t (:foreground "#00e5ff"))))
   '(log-view-message ((t (:foreground "#00e5ff"))))
   '(match ((t (:background "#0d2840" :foreground "#8ecede"))))
   '(modus-themes-search-current ((t (:background "#ff0044" :foreground "#050810"))))
   '(modus-themes-search-lazy ((t (:background "#0d2840" :foreground "#8ecede"))))
   '(newsticker-extra-face ((t (:foreground "#1a3a50" :height 0.8 :slant italic))))
   '(newsticker-feed-face ((t (:foreground "#ff0044" :height 1.2 :weight bold))))
   '(newsticker-treeview-face ((t (:foreground "#68b8cc"))))
   '(newsticker-treeview-selection-face ((t (:background "#0d2840" :foreground "#8ecede"))))
   '(tab-bar ((t (:background "#050810" :foreground "#2a4a5a"))))
   '(tab-bar-tab ((t (:background "#080c16" :underline nil))))
   '(tab-bar-tab-inactive ((t (:background "#050810" :foreground "#1a3a50"))))
   '(tab-bar-tab-group-current ((t (:background "#080c16" :foreground "#68b8cc" :underline t))))
   '(tab-bar-tab-group-inactive ((t (:background "#050810" :foreground "#2a4a5a"))))
   '(vc-dir-file ((t (:foreground "#00e5ff"))))
   '(vc-dir-header-value ((t (:foreground "#68b8cc"))))))

(defun my/apply-gits-theme ()
  "Apply the emacs-solo GITS theme preset."
  (my/ensure-modus-themes)
  (setq modus-themes-italic-constructs t
        modus-themes-bold-constructs t
        modus-themes-mixed-fonts nil
        modus-themes-prompts '(bold intense)
        modus-themes-common-palette-overrides my/gits-modus-palette)
  (my/disable-active-themes)
  (load-theme 'modus-vivendi t)
  (my/apply-gits-theme-faces))

