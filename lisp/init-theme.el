   '(modus-themes-search-current ((t (:background "#00ff41" :foreground "#0d0208"))))
   '(modus-themes-search-lazy ((t (:background "#003b00" :foreground "#00ff41"))))
   '(newsticker-extra-face ((t (:foreground "#005a00" :height 0.8 :slant italic))))
